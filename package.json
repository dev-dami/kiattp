{
  "name": "kiattp",
  "version": "0.2.0",
  "description": "A zero-dependency, fast, lightweight HTTP client library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./axios": {
      "types": "./dist/axios.d.ts",
      "import": "./dist/axios.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./plugins/retry": {
      "types": "./dist/plugins/retry.d.ts",
      "import": "./dist/plugins/retry.js"
    },
    "./plugins/logger": {
      "types": "./dist/plugins/logger.d.ts",
      "import": "./dist/plugins/logger.js"
    },
    "./plugins/timeout": {
      "types": "./dist/plugins/timeout.d.ts",
      "import": "./dist/plugins/timeout.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "size": "node scripts/size-check.mjs",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev-dami/kiattp.git"
  },
  "bugs": {
    "url": "https://github.com/dev-dami/kiattp/issues"
  },
  "homepage": "https://github.com/dev-dami/kiattp#readme",
  "keywords": [
    "http",
    "https",
    "fetch",
    "axios",
    "request",
    "client"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "axios": "^1.7.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
